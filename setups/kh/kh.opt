# You may enter a description between the BEGIN and END labels.
# BEGIN
# This is an implementation of the Kelvin-Helmholtz instability.
# The CI was taken from Colin P. McNally, Wladimir Lyra, and Jean-Claude Passy,
# arXiv 1111.1764v2 (10 May 2012).
# Recommended build:
# make SETUP=kh [GPU=1] view
# END
#-------------------------------------------------------------------------------
# From the list below, activate/deactivate the options that apply to your run.
#-------------------------------------------------------------------------------

#Dimension(s) of Simulation.
FARGO_OPT+=-DX
FARGO_OPT+=-DY
#FARGO_OPT+=-DZ

#Equation of State
FARGO_OPT+=-DADIABATIC

#Coordinate System.
FARGO_OPT +=  -DCARTESIAN

#Transport Algorithm
#FARGO_OPT += -DSTANDARD




#Cuda blocks
ifeq (${GPU}, 1)
FARGO_OPT += -DBLOCK_X=1
FARGO_OPT += -DBLOCK_Y=16
FARGO_OPT += -DBLOCK_Z=16
endif
