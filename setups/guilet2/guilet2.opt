MONITOR_SCALAR = TORQ

#Dimension(s) of Simulation

FARGO_OPT +=  -DX
FARGO_OPT +=  -DY
FARGO_OPT +=  -DZ

#FARGO_OPT += -DFLOAT

FARGO_OPT +=  -DISOTHERMAL
FARGO_OPT +=  -DSTOCKHOLM

FARGO_OPT += -DMHD
FARGO_OPT += -DPOTENTIAL
FARGO_OPT += -DVISCOSITY

#Coordinate System.

FARGO_OPT +=  -DCYLINDRICAL



#Cuda blocks
ifeq (${GPU}, 1)
FARGO_OPT += -DBLOCK_X=16
FARGO_OPT += -DBLOCK_Y=16
FARGO_OPT += -DBLOCK_Z=1
endif
